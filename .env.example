# Copy to .env on mato-server: cp .env.example .env

# Port published on the host (WireGuard / LAN)
ARGUS_PORT=8080

# Timezone
TZ=Europe/Bratislava

# Optional — proxy HA through ARGUS nginx (recommended on VPN deploy).
# mato-server must reach this URL. Pi on LAN example:
# ARGUS_HA_UPSTREAM=http://192.168.1.50:8123
# HA in Docker on same host:
# ARGUS_HA_UPSTREAM=http://host.docker.internal:8123
ARGUS_HA_UPSTREAM=

# Shown after argus-update (WireGuard server IP, same pattern as resell-radar)
ARGUS_PUBLIC_URL=http://10.8.0.1:8080
