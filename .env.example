# Copy to .env on mato-server: cp .env.example .env

# Port published on the host (WireGuard only — see ARGUS_BIND_IP)
ARGUS_PORT=9080

# WireGuard server IP on this host (only this address accepts connections)
ARGUS_BIND_IP=10.8.0.1

# Timezone
TZ=Europe/Bratislava

ARGUS_PUBLIC_URL=http://10.8.0.1:9080

# HA on mato-server — shared Docker network with ARGUS (recommended):
ARGUS_HA_UPSTREAM=http://homeassistant:8123

# Legacy: HA on host network (needs UFW rule for 172.17.0.0/16 → 8123):
# ARGUS_HA_UPSTREAM=http://host.docker.internal:8123

# Shown after argus-update (WireGuard server IP, same pattern as resell-radar)
ARGUS_PUBLIC_URL=http://10.8.0.1:9080
