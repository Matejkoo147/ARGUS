# Copy to secrets.yaml in the same folder (do not commit secrets.yaml)
#
# ESPHome has no "esphome secrets" command — edit secrets.yaml by hand.
# Generate api_encryption_key in PowerShell:
#   $b = New-Object byte[] 32; [Security.Cryptography.RandomNumberGenerator]::Create().GetBytes($b); [Convert]::ToBase64String($b)
#
wifi_ssid: "YOUR_WIFI_NAME"
wifi_password: "YOUR_WIFI_PASSWORD"
ap_password: "change_me_fallback_hotspot"
api_encryption_key: "paste_base64_key_from_powershell_here"
ota_password: "change_me_ota_password"
