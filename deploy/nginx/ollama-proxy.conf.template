# Ollama on host — browser uses https://ARGUS/api/ollama (avoids HTTPS→HTTP mixed content)
# Literal proxy_pass (no resolver) so host.docker.internal from extra_hosts works.
# Strip Origin/Referer — browser POST sends Origin; Ollama returns 403 unless OLLAMA_ORIGINS matches.
location /api/ollama/ {
    rewrite ^/api/ollama/?(.*)$ /$1 break;
    proxy_pass http://${ARGUS_OLLAMA_PROXY_HOST};
    proxy_http_version 1.1;
    proxy_set_header Host 127.0.0.1;
    proxy_set_header Origin "";
    proxy_set_header Referer "";
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 30s;
    proxy_read_timeout 600s;
    client_max_body_size 25m;
}
