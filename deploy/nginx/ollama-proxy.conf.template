# Ollama on host — browser uses https://ARGUS/api/ollama (avoids HTTPS→HTTP mixed content)
location /api/ollama/ {
    resolver 127.0.0.11 valid=30s ipv6=off;
    set $ollama_upstream ${ARGUS_OLLAMA_PROXY_HOST};
    rewrite ^/api/ollama/?(.*)$ /$1 break;
    proxy_pass http://$ollama_upstream;
    proxy_http_version 1.1;
    proxy_set_header Host ${ARGUS_OLLAMA_PROXY_HOST};
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_connect_timeout 30s;
    proxy_read_timeout 600s;
    client_max_body_size 25m;
}
