# Local Whisper STT (Brave blocks Google speech — see docker compose profile stt)
location /api/stt/ {
    resolver 127.0.0.11 valid=30s ipv6=off;
    set $stt_upstream ${ARGUS_STT_PROXY_HOST};
    rewrite ^/api/stt/?(.*)$ /$1 break;
    proxy_pass http://$stt_upstream;
    proxy_http_version 1.1;
    proxy_set_header Host ${ARGUS_STT_PROXY_HOST};
    proxy_set_header X-Real-IP $remote_addr;
    client_max_body_size 25m;
    proxy_read_timeout 180s;
    proxy_connect_timeout 30s;
}
